{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npx prisma generate && npm run build",
  "git": {
    "deploymentEnabled": {
      "master": false,
      "*": false
    }
  },
  "crons": [
    {
      "path": "/api/cron/janitors",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/task-coordinator",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/pod-repair",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/pr-monitor",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/sphinx-summary",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/notification-dispatcher",
      "schedule": "*/5 * * * *"
    }
  ]
}
