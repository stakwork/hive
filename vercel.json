{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "master": false,
      "*": false
    }
  },
  "crons": [{
      "path": "/api/cron/janitors",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/task-coordinator",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/pod-repair",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/pr-monitor",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/sphinx-summary",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/notification-dispatcher",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/pod-scaler",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/discord-sync",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/canvas-janitor",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/llm-model-sync",
      "schedule": "0 1 * * *"
    }
  ]
}