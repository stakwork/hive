model Feature {
  id                  String                @id @default(cuid())
  title               String
  workspaceId         String                @map("workspace_id")
  assigneeId          String?               @map("assignee_id")
  status              FeatureStatus         @default(BACKLOG)
  createdById         String                @map("created_by_id")
  updatedById         String                @map("updated_by_id")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")
  architecture        String?
  brief               String?
  requirements        String?
  deleted             Boolean               @default(false)
  deletedAt           DateTime?             @map("deleted_at")
  personas            String[]              @default([])
  priority            FeaturePriority       @default(LOW)
  diagramS3Key        String?               @map("diagram_s3_key")
  diagramUrl          String?               @map("diagram_url")
  stakworkProjectId   Int?                  @map("stakwork_project_id")
  workflowCompletedAt DateTime?             @map("workflow_completed_at")
  workflowStartedAt   DateTime?             @map("workflow_started_at")
  workflowStatus      WorkflowStatus?       @default(PENDING) @map("workflow_status")
  isFastTrack         Boolean               @default(false) @map("is_fast_track")
  planUpdatedAt       DateTime?             @map("plan_updated_at")
  model               String?
  milestoneId         String?               @map("milestone_id")
  initiativeId        String?               @map("initiative_id")
  // Cuids of features that must reach completion before this feature
  // can start. Mirror of `Task.dependsOnTaskIds` — same flat-array
  // posture, same cross-workspace freedom (no per-workspace constraint
  // on the blocker). Cleanup-on-delete and cycle-check live in the
  // feature service. The org canvas projector emits a synthetic
  // `synthetic:feature-blocks:<blockerId>:<blockedId>` edge between
  // pairs where BOTH endpoints are anchored to the same initiative.
  dependsOnFeatureIds String[]              @default([]) @map("depends_on_feature_ids")
  selectedRepositoryIds String[]            @default([]) @map("selected_repository_ids")
  /**
   * The canvas conversation (`SharedConversation.id`) that "owns" this
   * feature — typically the one where the user approved the
   * `propose_feature` proposal that created the row. Populated by
   * `handleApproval.approveFeature` at create time; also populated
   * lazily by `send_to_feature_planner` if a canvas conversation
   * messages a planner for a feature that wasn't proposed there.
   *
   * Fan-out: when this feature's planner writes an ASSISTANT
   * message (Stakwork webhook at `/api/chat/response`), the worker
   * appends a `CanvasChatMessage`-shaped row to the owning
   * conversation's `messages` JSON via
   * `fanOutPlannerMessageToCanvas`.
   *
   * Singular in v1 (one canvas conversation owns the feature). See
   * "Future seams" in `docs/plans/canvas-agent-manages-planners.md`
   * for the join-table promotion path.
   *
   * No FK to `SharedConversation` — conversations can be deleted
   * (user clears chat); the fan-out worker treats a missing target
   * as a no-op.
   */
  parentCanvasConversationId String?         @map("parent_canvas_conversation_id")
  /**
   * Per-feature auto-respond override for the canvas agent.
   * null  = inherit global (`User.canvasAutonomousTurns`)
   * true  = always auto-respond for this feature (even if global is off)
   * false = never auto-respond for this feature (even if global is on)
   */
  autoRespond         Boolean?              @map("auto_respond")
  /**
   * The originating ErrorIssue this Feature was created to fix — set
   * when the Feature is created via "Fix in Plan Mode" from the Errors
   * dashboard. Nullable (most Features have no linked error).
   * Many Features may point to the same ErrorIssue across repeated
   * fix attempts; onDelete: SetNull so deleting a Feature never
   * cascades to the error.
   */
  errorIssueId        String?               @map("error_issue_id")
  errorIssue          ErrorIssue?           @relation(fields: [errorIssueId], references: [id], onDelete: SetNull)
  agentLogs           AgentLog[]
  chatMessages        ChatMessage[]
  assignee            User?                 @relation("FeatureAssignee", fields: [assigneeId], references: [id])
  createdBy           User                  @relation("FeatureCreator", fields: [createdById], references: [id])
  updatedBy           User                  @relation("FeatureUpdater", fields: [updatedById], references: [id])
  workspace           Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  milestone           Milestone?            @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  initiative          Initiative?           @relation(fields: [initiativeId], references: [id], onDelete: SetNull)
  notifications       NotificationTrigger[]
  phases              Phase[]
  scorerDigest        ScorerDigest?
  screenshots         Screenshot[]
  stakworkRuns        StakworkRun[]
  tasks               Task[]
  userStories         UserStory[]
  whiteboard          Whiteboard?
  activeViewers       UserFeaturePresence[]

  @@index([workspaceId])
  @@index([assigneeId])
  @@index([createdById])
  @@index([status])
  @@index([deleted])
  @@index([milestoneId])
  @@index([initiativeId])
  @@index([parentCanvasConversationId])
  @@index([errorIssueId])
  @@map("features")
}

