  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  initiative   Initiative      @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  assignee     User?           @relation("MilestoneAssignee", fields: [assigneeId], references: [id])
  creator      User?           @relation("MilestoneCreator", fields: [createdById], references: [id])
  features     Feature[]

  @@unique([initiativeId, sequence])
  @@index([initiativeId])
  @@map("milestones")
}

enum ChannelStatus {
  ACTIVE
  ERRORED
  DISABLED_BY_SYSTEM
}

model DiscordChannel {
  id                  String        @id @default(cuid())
  workspaceId         String        @map("workspace_id")
  guildId             String        @map("guild_id")
  guildName           String        @map("guild_name")
  channelId           String        @map("channel_id")
  channelName         String        @map("channel_name")
  channelType         Int           @default(0) @map("channel_type")
  enabled             Boolean       @default(true)
  status              ChannelStatus @default(ACTIVE)
  consecutiveFailures Int           @default(0) @map("consecutive_failures")
  lastMessageId       String?       @map("last_message_id")
  lastSyncedAt        DateTime?     @map("last_synced_at")
  syncError           String?       @map("sync_error")
  workspace           Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, channelId])
  @@map("discord_channels")
}

enum DeferredChatActionStatus {
  PENDING
  FIRED
  CANCELLED
  FAILED
}

model DeferredChatAction {
  id             String                   @id @default(cuid())
  conversationId String                   @map("conversation_id")
  orgId          String                   @map("org_id")
  userId         String                   @map("user_id")
  query          String
  description    String
  fireAt         DateTime                 @map("fire_at")
  status         DeferredChatActionStatus @default(PENDING)
  createdAt      DateTime                 @default(now()) @map("created_at")
  firedAt        DateTime?                @map("fired_at")

  @@index([status, fireAt])
  @@map("deferred_chat_actions")
}

/// A recurring scheduled prompt for the org canvas chat. The per-minute
/// automation cron (`/api/cron/automations`) finds rows whose `nextRunAt`
/// has passed, creates a brand-new org-canvas `SharedConversation`, runs the
/// canvas agent with `prompt`, then advances `nextRunAt` to the next
/// occurrence of `timeOfDay` in `timezone`. The freshly-created conversation
/// is recorded on `lastRunConversationId` with `lastRunSeenAt = null` so the
/// canvas page can auto-open the most recent unseen run on load.
model Automation {
  id                    String    @id @default(cuid())
  sourceControlOrgId    String    @map("source_control_org_id")
  userId                String    @map("user_id")
  name                  String
  prompt                String
  /// 24-hour wall-clock time "HH:MM", interpreted in `timezone`.
  timeOfDay             String    @map("time_of_day")
  /// IANA timezone, e.g. "America/Los_Angeles". The wall-clock `timeOfDay`
  /// is resolved against this zone (DST-aware) to compute `nextRunAt`.
  timezone              String    @default("UTC")
  enabled               Boolean   @default(true)
  /// UTC instant of the next scheduled fire. Indexed for the cron sweep.
  nextRunAt             DateTime  @map("next_run_at")
  lastRunAt             DateTime? @map("last_run_at")
  /// The org-canvas SharedConversation created by the most recent run.
  lastRunConversationId String?   @map("last_run_conversation_id")
  /// Null while the most recent run hasn't been surfaced to the user yet;
  /// set once the canvas auto-opens (or the user dismisses) that run.
  lastRunSeenAt         DateTime? @map("last_run_seen_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceControlOrg SourceControlOrg @relation(fields: [sourceControlOrgId], references: [id], onDelete: Cascade)

  @@index([enabled, nextRunAt])
  @@index([sourceControlOrgId, userId])
  @@map("automations")
}

model WorkflowSummary {
  id          String    @id @default(cuid())
  workflowId  Int       @map("workflow_id")
  workspaceId String    @map("workspace_id")
  cacheKey    String    @map("cache_key")
  versionIds  Json      @map("version_ids")
  content     String?   @db.Text
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workflowId, cacheKey])
  @@index([workspaceId])
  @@map("workflow_summaries")
}

// ─── Shared/global prompt management ────────────────────────────────────────

enum PromptSyncStatus {
  OK
  PENDING // local write succeeded; Stakwork push failed — needs retry
  FAILED
}

model Prompt {
  id                 String           @id @default(cuid())
  name               String           @unique // shared/global scope; UPPERCASE_UNDERSCORE
  value              String // LIVE value — cache of the PUBLISHED version only; drafts do NOT update this field
  description        String?
  agentNames         String[]         @default([]) @map("agent_names")
  publishedVersionId String?          @map("published_version_id")
  stakworkId         Int?             @map("stakwork_id") // Stakwork numeric prompt id, for sync
  syncStatus         PromptSyncStatus @default(OK) @map("sync_status")
  lastSyncedAt       DateTime?        @map("last_synced_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  versions           PromptVersion[]
  publishedVersion   PromptVersion?   @relation("PublishedVersion", fields: [publishedVersionId], references: [id])
  promptDailyRuns    PromptDailyRun[]
  usages             PromptUsage[]

  @@index([syncStatus])
  @@map("prompts")
}

model PromptVersion {
  id            String   @id @default(cuid())
  promptId      String   @map("prompt_id")
  versionNumber Int      @map("version_number")
  value         String // FULL snapshot of THIS version's text — exact replay is a plain DB read
  description   String?
  whodunnit     String? // userId or system label (e.g. "stakwork-seed")
  published     Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")
  prompt        Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  publishedForPrompts Prompt[] @relation("PublishedVersion")
  promptDailyRuns     PromptDailyRun[]

  @@unique([promptId, versionNumber])
  @@index([promptId])
  @@index([promptId, published])
  @@map("prompt_versions")
}

model PromptDailyRun {
  id                String        @id @default(cuid())
  promptId          String        @map("prompt_id")
  versionId         String?       @map("version_id")
  stakworkPromptId  Int?          @map("stakwork_prompt_id")
  stakworkVersionId Int?          @map("stakwork_version_id")
  workflowId        Int           @map("workflow_id")
  customerId        Int           @map("customer_id")
  runDate           DateTime      @db.Date @map("run_date")
  runCount          Int           @map("run_count")
  hiveVersionId     String        @map("hive_version_id")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  prompt            Prompt        @relation(fields: [promptId], references: [id], onDelete: Cascade)
  version           PromptVersion? @relation(fields: [versionId], references: [id])

  @@unique([promptId, versionId, runDate])
  @@index([promptId, runDate])
  @@index([hiveVersionId])
  @@map("prompt_daily_runs")
}

model PromptUsage {
  id           String   @id @default(cuid())
  workspaceId  String?  @map("workspace_id")
  promptId     String?  @map("prompt_id")
  promptName   String   @map("prompt_name")
  workflowId   Int      @map("workflow_id")
  workflowName String?  @map("workflow_name")
  stepId       String   @map("step_id")
  stepUniqueId String?  @map("step_unique_id")
  fieldPath    String?  @map("field_path")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  prompt    Prompt?    @relation(fields: [promptId], references: [id], onDelete: SetNull)

  // Per-workspace unique constraint (NULL != NULL in Postgres so this only covers non-null workspace rows)
  @@unique([workspaceId, workflowId, stepId, promptName])
  @@index([promptName])
  @@index([promptId])
  @@index([workspaceId])
  @@map("prompt_usages")
}

// ── Error tracking ───────────────────────────────────────────────────────────

enum ErrorIssueStatus {
  UNRESOLVED
  RESOLVED
  IGNORED
}

/// Grouped error issue — one row per unique (workspace, repoKey, fingerprint).
/// repoKey is non-null: it is the resolved repositoryId when the repo matched,
/// otherwise a normalised raw identifier from the client, or the literal
/// "unknown". This avoids the Postgres NULL-uniqueness pitfall.
model ErrorIssue {
  id             String           @id @default(cuid())
  workspaceId    String           @map("workspace_id")
  repositoryId   String?          @map("repository_id")
  repoKey        String           @map("repo_key")
  fingerprint    String
  exceptionType  String           @map("exception_type")
  title          String
  status         ErrorIssueStatus @default(UNRESOLVED)
  occurrenceCount Int             @default(1) @map("occurrence_count")
  firstSeenAt    DateTime         @map("first_seen_at")
  lastSeenAt     DateTime         @map("last_seen_at")
  environment    String?
  release        String?
  metadata       Json?
  kgRefId        String?          @map("kg_ref_id")
  /// Regression-correlation fields — populated asynchronously by the correlation service
  /// after an onset event (new issue, regression reopen, or burst spike).
  correlatedPrNumber      Int?      @map("correlated_pr_number")
  correlatedPrUrl         String?   @map("correlated_pr_url")
  correlatedCommitSha     String?   @map("correlated_commit_sha")
  correlationConfidence   String?   @map("correlation_confidence")
  correlationComputedAt   DateTime? @map("correlation_computed_at")
  correlationCandidates   Json?     @map("correlation_candidates")
  /// Blast-radius impact score — derived from the PageRank/fan-in centrality of
  /// the File/Function KG nodes this issue references. Populated best-effort by
  /// the error-impact cron and opportunistically at ingest. null = unscored.
  impactScore     Float?    @map("impact_score")
  impactScoredAt  DateTime? @map("impact_scored_at")
  /// Small breakdown: top contributing node name/type, its pagerank, in_degree.
  impactMeta      Json?     @map("impact_meta")
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  repository     Repository?      @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
  events         ErrorEvent[]
  features       Feature[]

  @@unique([workspaceId, repoKey, fingerprint])
  @@index([workspaceId])
  @@index([repositoryId])
  @@index([lastSeenAt])
  @@index([impactScore])
  @@map("error_issues")
}

/// Individual occurrence of an error linked to its grouped ErrorIssue.
model ErrorEvent {
  id             String      @id @default(cuid())
  issueId        String      @map("issue_id")
  workspaceId    String      @map("workspace_id")
  repositoryId   String?     @map("repository_id")
  repoKey        String      @map("repo_key")
  blobUrl        String      @map("blob_url")
  exceptionType  String      @map("exception_type")
  message        String
  environment    String?
  release        String?
  requestContext Json?       @map("request_context")
  metadata       Json?
  fingerprint    String
  commitSha      String?     @map("commit_sha")
  createdAt      DateTime    @default(now()) @map("created_at")
  issue          ErrorIssue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  workspace      Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  repository     Repository? @relation(fields: [repositoryId], references: [id], onDelete: SetNull)

  @@index([issueId])
  @@index([workspaceId])
  @@index([repositoryId])
  @@index([createdAt])
  @@map("error_events")
}

/// Cross-realm typed edge between two URN-addressed nodes.
/// Persists relationships between Postgres entities, Canvas authored nodes,
/// and KG concepts that cannot be expressed via FK columns alone.
model UrnEdge {
  id        String           @id @default(cuid())
  orgId     String           @map("org_id")
  fromUrn   String           @map("from_urn")
  toUrn     String           @map("to_urn")
  type      String
  createdAt DateTime         @default(now()) @map("created_at")
  org       SourceControlOrg @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, fromUrn, toUrn, type])
  @@index([fromUrn])
  @@index([toUrn])
  @@index([orgId, fromUrn])
  @@index([orgId, toUrn])
  @@map("urn_edges")
}

/// Captures raw STT transcript → final submitted text correction pairs for
/// voice dictation improvement. Opt-in only; recorded when a user edits
/// a voice-transcribed message before submitting.
model VoiceCorrectionLearning {
  id            String     @id @default(cuid())
  userId        String     @map("user_id")
  workspaceId   String?    @map("workspace_id")
  surface       String     // task_chat | plan_chat | plan_start | task_start | whiteboard | sidebar
  rawTranscript String     @db.Text @map("raw_transcript")
  preVoiceText  String     @db.Text @map("pre_voice_text")
  finalText     String     @db.Text @map("final_text")
  createdAt     DateTime   @default(now()) @map("created_at")
  user          User       @relation(fields: [userId], references: [id])
  workspace     Workspace? @relation(fields: [workspaceId], references: [id])

  @@index([userId])
  @@index([surface])
  @@index([createdAt])
  @@map("voice_correction_learnings")
}


model LegalBenchmarkRun {
  id               String   @id @default(cuid())
  workspaceId      String
  taskSlug         String
  taskTitle        String
  status           String   @default("PENDING") // PENDING | RUNNING | SCORING | COMPLETE | FAILED
  runnerProjectId  Int?
  scorerProjectId  Int?
  runnerOutputUrl  String?
  runnerOutputText String?  @db.Text
  scoreJson        String?  @db.Text
  errorMessage     String?
  evalTriggerRef   String?   // Jarvis EvalTrigger ref_id; written at run start, read by scorer webhook
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([workspaceId])
  @@index([taskSlug])
}
