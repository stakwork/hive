enum WorkspaceTransactionType {
  LIGHTNING
  STRIPE
}

model Connection {
  id           String           @id @default(cuid())
  slug         String
  name         String
  summary      String           @db.Text
  diagram      String?          @db.Text
  architecture String?          @db.Text
  openApiSpec  String?          @map("open_api_spec") @db.Text
  prompt       String?          @db.Text
  createdBy    String           @map("created_by")
  orgId        String           @map("org_id")
  org          SourceControlOrg @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@unique([orgId, slug])
  @@index([orgId])
  @@map("connections")
}

/// System-canvas document attached to a SourceControlOrg. Each org has one
/// root canvas (ref = "") plus any number of nested sub-canvases addressed
/// by `ref`; nodes in one canvas can point at another via `ref`, producing a
/// drill-down graph. `data` stores the full CanvasData JSON (nodes, edges,
/// theme hints, lanes) as produced/consumed by system-canvas-react.
///
/// The empty-string sentinel for the root (rather than NULL) avoids
/// PostgreSQL's "NULL is never equal" semantics on the composite unique,
/// which would otherwise let two rows claim to be "root" for the same org.
model Canvas {
  id        String           @id @default(cuid())
  orgId     String           @map("org_id")
  ref       String           @default("")
  data      Json
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  org       SourceControlOrg @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, ref])
  @@index([orgId])
  @@map("canvases")
}

model WorkspaceTransaction {
  id                 String                   @id @default(cuid())
  workspaceId        String?                  @map("workspace_id")
  type               WorkspaceTransactionType
  amountSats         Int?                     @map("amount_sats")
  btcPriceUsd        Float?                   @map("btc_price_usd")
  amountUsd          Float?                   @map("amount_usd")
  currency           String?
  lightningPaymentId String?                  @unique @map("lightning_payment_id")
  fiatPaymentId      String?                  @unique @map("fiat_payment_id")
  createdAt          DateTime                 @default(now()) @map("created_at")
  workspace          Workspace?               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lightningPayment   LightningPayment?        @relation(fields: [lightningPaymentId], references: [id])
  fiatPayment        FiatPayment?             @relation(fields: [fiatPaymentId], references: [id])

  @@index([workspaceId])
  @@map("workspace_transactions")
}

model ScorerDigest {
